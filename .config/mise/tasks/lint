#!/usr/bin/env bash
#MISE description="Run all repository lint checks (CI parity with lint.yml)"
# Anchor to the repo root via this file's real location so the task works
# no matter where it is invoked from (global tasks run in $HOME by default).
set -eu
cd "$(dirname "$(readlink -f "$0")")/../../.."

echo "==> shellcheck -f gcc (zsh rc)"
test "$(find .config/zsh/.zshrc .config/zsh/rc -maxdepth 1 -type f -print0 | xargs -0 shellcheck -f gcc | grep -v "SC1036\|SC1056\|SC1070\|SC1072\|SC1073\|SC1083\|SC1091\|SC2034\|SC2139\|SC2148\|SC1090\|SC1117\|SC2206\|SC1009\|SC2016\|SC2046\|SC2154" | tee -a /dev/stderr | wc -l)" -le 0

echo "==> shellcheck -f gcc (*.sh)"
test "$(git ls-files | grep "\.sh$" | xargs shellcheck -f gcc | grep -v "SC2086\|SC2046\|SC1090\|SC2034\|SC2005\|SC2154\|SC1091" | tee -a /dev/stderr | wc -l)" -le 0

echo "==> selene -q ."
selene -q .

echo "==> bash -n install.sh"
bash -n install.sh

echo "==> nixfmt --check (*.nix)"
git ls-files -z -- '*.nix' | xargs -0 nixfmt --check

echo "All lint checks passed"
