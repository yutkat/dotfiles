{
  // -------------------------------------------------------------------------
  // Global configuration
  // -------------------------------------------------------------------------
  "layer": "bottom",
  "position": "bottom",
  "height": 26,
  "modules-left": [
    "hyprland/workspaces"
  ],
  // "modules-center": ["custom/window"],
  "modules-right": [
    "custom/primary",
    "custom/clipboard",
    "network",
    "idle_inhibitor",
    "cpu",
    "temperature",
    "memory",
    "disk",
    "custom/keyboard-layout",
    "backlight",
    "pulseaudio",
    "battery",
    "custom/dunst",
    "custom/pacman",
    "custom/nix-update",
    "custom/uptime",
    "tray",
    "clock#date",
    "clock#time"
  ],
  // -------------------------------------------------------------------------
  // Modules
  // -------------------------------------------------------------------------
  "hyprland/workspaces": {
    "format": "{name}",
    "on-scroll-up": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"e+1\" })'",
    "on-scroll-down": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"e-1\" })'",
    "show-special": false,
    "ignore-workspaces": [
      "(special:)?special:scratch_term"
    ]
  },
  "backlight": {
    "format": "’åģ {percent}%",
    "interval": 2,
    "on-scroll-up": "brightnessctl set +2%",
    "on-scroll-down": "brightnessctl set 2%-"
  },
  "battery": {
    "interval": 10,
    "states": {
      "warning": 25,
      "critical": 15
    },
    // Connected to AC
    "format": "’ā¦ {icon}  {capacity}%", // Icon: bolt
    // Not connected to AC
    "format-discharging": "{icon} {capacity}%",
    "format-icons": [
      "’ēĆ", // Icon: battery-full
      "’ēü", // Icon: battery-three-quarters
      "’ēé", // Icon: battery-half
      "’ēā", // Icon: battery-quarter
      "’ēä" // Icon: battery-empty
    ],
    "tooltip": true
  },
  "clock#time": {
    "interval": 1,
    "format": "{:%H:%M:%S}",
    "tooltip": false
    // "timezone": "Europe/Warsaw"
  },
  "clock#date": {
    "interval": 10,
    "format": "’ü│ {:%Y/%m/%d(%a)}", // Icon: calendar-alt
    "tooltip-format": "{:%Y %B %e (%A)}",
    "locale": "C.UTF-8"
    // "timezone": "Europe/Warsaw"
  },
  "cpu": {
    "interval": 3,
    "format": "\uf4bc {usage}% ({load})", // Icon: microchip
    "states": {
      "warning": 70,
      "critical": 90
    }
  },
  "idle_inhibitor": {
    "format": "{icon} ",
    "format-icons": {
      "activated": "’ü«",
      "deactivated": "’ü░"
    }
  },
  "memory": {
    "interval": 3,
    "format": "Ņē” {}%", // Icon: memory
    "states": {
      "warning": 70,
      "critical": 90
    }
  },
  "disk": {
    "format": "\uf0a0 {percentage_used}%",
    "path": "/",
    "states": {
      "warning": 90,
      "critical": 95
    }
  },
  "network": {
    "interval": 3,
    "format-wifi": "’ć½ {essid}", // Icon: wifi
    "format-ethernet": "\udb80\ude00 {ifname}: {ipaddr}/{cidr}", // Icon: ethernet
    "format-disconnected": "ŌÜĀ  Disconnected",
    "tooltip-format": "{ifname}: {ipaddr} (signal: {signalStrength}%)"
  },
  "pulseaudio": {
    "scroll-step": 2,
    "format": "{icon}  {volume}%",
    "format-muted": "’Ü® Muted", // Icon: volume-mute
    "format-icons": {
      "headphones": "’Ćź", // Icon: headphones
      "handsfree": "’¢É", // Icon: headset
      "headset": "’¢É", // Icon: headset
      "phone": "’éĢ", // Icon: phone
      "portable": "’éĢ", // Icon: phone
      "car": "’å╣", // Icon: car
      "default": [
        "’Ć¦",
        "’Ć©"
      ] // Icons: volume-down, volume-up
    },
    "on-click": "~/.config/i3/scripts/set-default-sound-device.sh",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "tooltip": true
  },
  "temperature": {
    "critical-threshold": 85,
    "interval": 3,
    "format": "{icon} {temperatureC}┬░C",
    "format-icons": [
      "’ŗŗ", // Icon: temperature-empty
      "’ŗŖ", // Icon: temperature-quarter
      "’ŗē", // Icon: temperature-half
      "’ŗł", // Icon: temperature-three-quarters
      "’ŗł" // Icon: temperature-full
    ],
    "tooltip": true
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  // -------------------------------------------------------------------------
  // Custom Modules
  // -------------------------------------------------------------------------
  "custom/primary": {
    "format": "’ü┐ {}",
    "exec": "~/.config/waybar/scripts/clipboard.sh --primary",
    "on-click": "~/.config/waybar/scripts/clipboard.sh --toggle; pkill -SIGRTMIN+8 waybar",
    "restart-interval": 2,
    "escape": true
  },
  "custom/clipboard": {
    "format": "ŅĄ╗ {}",
    "exec": "~/.config/waybar/scripts/clipboard.sh --clipboard",
    "on-click": "~/.config/waybar/scripts/clipboard.sh --toggle; pkill -SIGRTMIN+8 waybar",
    "restart-interval": 2,
    "escape": true
  },
  "custom/dunst": {
    "format": "{} ",
    "exec": "~/.config/waybar/scripts/dunst.sh",
    "on-click": "dunstctl set-paused toggle",
    "restart-interval": 1
  },
  "custom/pacman": {
    "format": "’üó {} updates available",
    "exec": "checkupdates | wc -l",
    "exec-if": "[ -f /etc/arch-release ] && [ $(checkupdates | wc -l) -gt 0 ]",
    "interval": 3600,
    "on-click": "checkupdates; pkill -SIGRTMIN+8 waybar"
  },
  "custom/nix-update": {
    "format": "’üó {} updates available",
    "exec": "~/.config/waybar/scripts/check-nix-updates.sh",
    "exec-if": "[ -f /etc/NIXOS ] && [ $(~/.config/waybar/scripts/check-nix-updates.sh) -gt 0 ]",
    "interval": 3600,
    "on-click": "~/.config/waybar/scripts/check-nix-updates.sh"
  },
  "custom/window": {
    "exec": "~/.config/waybar/scripts/window_title.sh",
    "interval": 1
  },
  "custom/uptime": {
    "format": "’ĆŚ {}",
    "exec": "uptime | awk '{print $3}'|sed 's/,//'",
    "interval": 60
  }
}
